# QuantGPT Environment Configuration
# Copy this file to .env and fill in your values

# LLM — DeepSeek (OpenAI-compatible)
# Optional: leave empty to use expression-only mode (no natural language input)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Strategy LLM (optional, falls back to DEEPSEEK_* if not set)
STRATEGY_LLM_API_KEY=
STRATEGY_LLM_BASE_URL=
STRATEGY_LLM_MODEL=

# Database — SQLite (default, zero config) or PostgreSQL
# Leave empty for SQLite (./quantgpt.db), or set PostgreSQL URL:
# DATABASE_URL=postgresql+asyncpg://quantgpt:your_password@localhost:5433/quantgpt
DATABASE_URL=

# Local Development Mode
# Set to true to disable authentication (no login required, no SMTP needed)
# WARNING: Never enable in production!
AUTH_DISABLED=false

# JWT Authentication (not needed if AUTH_DISABLED=true)
JWT_SECRET_KEY=generate_a_random_64_char_hex_string
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP — Email verification codes
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=your_email@example.com
SMTP_USE_TLS=true

# Feedback Webhook (optional, Feishu/Lark)
QUANTGPT_FEEDBACK_WEBHOOK=
QUANTGPT_FEEDBACK_WEBHOOK_SECRET=

# RiceQuant (rqdatac) — primary A-share data source (optional)
RQDATAC_USERNAME=
RQDATAC_PASSWORD=

# JoinQuant — Playwright browser automation (optional)
JQ_USERNAME=
JQ_PASSWORD=
JQ_HEADLESS=true
JQ_BACKTEST_TIMEOUT=600

# Admin
QUANTGPT_ADMIN_PASSWORD=change_this_password

# App tuning (optional)
QUANTGPT_MAX_ACTIVE_TASKS=5
QUANTGPT_RATE_LIMIT=10
QUANTGPT_CORS_ORIGINS=http://localhost:5173,http://localhost:8002
